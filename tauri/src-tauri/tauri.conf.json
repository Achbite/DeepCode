{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "DeepCode",
  "version": "0.1.0",
  "identifier": "com.deepcode.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @deepcode/client dev",
    "beforeBuildCommand": "pnpm --filter @deepcode/client build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../client/dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeepCode",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "DeepCode AI 代码工作台",
    "longDescription": "DeepCode 是一个轻量级 AI Agent 代码工作台，前端基于 React + Monaco，后端采用 Tauri (Rust) + 可选 Node 服务。",
    "resources": {
      "Microsoft.WebView2.FixedVersionRuntime.x64": "Microsoft.WebView2.FixedVersionRuntime.x64"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "./Microsoft.WebView2.FixedVersionRuntime.x64/"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["English", "SimpChinese"],
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {}
}
