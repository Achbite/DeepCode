# ---- 依赖 ----
node_modules/
*/node_modules/
**/node_modules/

# ---- 构建产物 ----
**/dist/
**/build/
target/
**/target/
**/src-tauri/gen/
**/.next/
**/.turbo/
**/.vite/
.build-cache/
.pnpm-store/

# ---- 本地可执行打包产物 ----
# bin/ 用于输出统一分发目录；二进制产物不入库
bin/*
!bin/.gitkeep

# ---- 日志 ----
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# ---- 环境与密钥 ----
.env
.env.*
!.env.example

# ---- IDE / 系统 ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ---- 工程临时文件 ----
_check_output.txt
_agent_tmp_*
*.tsbuildinfo
.deepcode-preview-config*/

# Root Rust kernel workspace is library-only during the skeleton stage.
/Cargo.lock

# ---- 默认工作区运行产物 ----
# workspace/ 目录本身保留，但内部用户数据不入库；如需用户工作区不入库，取消下一行注释
# workspace/**
# 但保留 .gitkeep
!workspace/.gitkeep
