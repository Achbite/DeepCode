{
  "name": "@deepcode/client",
  "version": "0.5.24",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:deepcode-gui": "vite --config vite.deepcode-gui.config.ts",
    "build": "tsc && vite build",
    "build:deepcode-gui": "tsc && vite build --config vite.deepcode-gui.config.ts && [ ! -f dist-deepcode-gui/deepcode-gui.html ] || cp dist-deepcode-gui/deepcode-gui.html dist-deepcode-gui/index.html",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@deepcode/protocol": "workspace:*",
    "@deepcode/session-core": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "monaco-editor": "^0.55.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
